  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: LineTable_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: c884be7acc7ff0f4db5cf6f4614ad1f2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 157063204864
    m_Localized: 'Capsley: Hello, I am Mr Capsley.'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839680
    m_Localized: 'Capsley: I''m only going to ask this once'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839681
    m_Localized: 'Capsley: Who are you then?'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839682
    m_Localized: I'm Capsule, but my friends call me "Tic Tac". No idea why...
    m_Metadata:
      m_Items: []
  - m_Id: 157189033984
    m_Localized: The name's Triquandle.
    m_Metadata:
      m_Items: []
  - m_Id: 157189033985
    m_Localized: Pyramid. Why - who wants to know?
    m_Metadata:
      m_Items: []
  - m_Id: 157189033986
    m_Localized: 'Capsley: Nice to meet you {0}!'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228288
    m_Localized: 'Capsley: No need to be so rude...'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228289
    m_Localized: 'Capsley: Maybe you should be called Grumpy {0}.'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228290
    m_Localized: I said I would only say it once
    m_Metadata:
      m_Items: []
  - m_Id: 157193228291
    m_Localized: '*black screen, text fades in, mother crystal starts to fade in
      very slowly during the exposition*'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228292
    m_Localized: "Mother Crystal:\u201CChild of the sky\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228293
    m_Localized: "Mother Crystal:\u201CDo you hear my voice?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228294
    m_Localized: "\u201CMother Crystal:I am the heart and soul of The Islands of
      Ethor.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228295
    m_Localized: "Mother Crystal:\u201CIt is through I that the islands stay bound
      as one.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228296
    m_Localized: "Mother Crystal:\u201CHowever, that couldn\u2019t be any further
      from the truth as of late\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228297
    m_Localized: "Mother Crystal:\u201CLong ago, my light shone freely throughout
      all the land. The people of Ethor utilized my power, and the world flourished.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228298
    m_Localized: "Mother Crystal:\u201CBut as people\u2019s appetite for more power
      grew, so did the imbalance, and the threat of calamity arose. In order to prevent
      such a catastrophe, I did what I must: I fractured the land and scattered my
      power.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228299
    m_Localized: "Mother Crystal:\u201CEach island carries a fraction of my essence,
      but their crystals are frail, leaving their lands in distress.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228300
    m_Localized: '*zoom in shot of mother crystal (should be fully faded in by now)'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228301
    m_Localized: (Mother crystal lets off a brief sparkle)
    m_Metadata:
      m_Items: []
  - m_Id: 157193228302
    m_Localized: "Mother Crystal:\u201CChild\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228303
    m_Localized: "Mother Crystal:\u201CThe binding light of the Isles of Ethor is
      fading\u2026\u201D (crystal cracks)"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228304
    m_Localized: "Mother Crystal:\u201CThe islands cry out for a hero, and the land
      yearns to restore its unity\u201D (light shoots out, screen starts shaking)"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228305
    m_Localized: '*screen flashes white, hard cut to Sky waking up*'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745652
    m_Localized: "Judith: Best of luck on your journey. I\u2019m sure you\u2019re
      gonna need it."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745651
    m_Localized: 'Judith: You too. And I really do mean that.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745650
    m_Localized: 'Sky: I wish you the best, Judith.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745649
    m_Localized: 'Sky: Can do.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745648
    m_Localized: 'Judith: Make sure you talk to them.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745647
    m_Localized: "Judith: I don\u2019t know the specifics, but I\u2019m sure they
      also have problems related to their crystals."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745646
    m_Localized: "Judith: Good. That\u2019s good."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745645
    m_Localized: "Sky: That\u2019s the plan."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745644
    m_Localized: "Judith: You\u2019re going to go to all the islands, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745643
    m_Localized: 'Sky: Of course, Judith. I hope things can get a little easier for
      you now.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745642
    m_Localized: 'Judith: Thank you.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745641
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745640
    m_Localized: "Judith: I\u2026I don\u2019t believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745639
    m_Localized: 'Sky: I told you I could do it!'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745638
    m_Localized: 'Judith: Back already? I knew you were full of it.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745637
    m_Localized: (If the character goes back to Judith before activating the Crystal,
      she will say this:)
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745636
    m_Localized: Judith returns to mining the ice around her. You start on your journey
      toward the crystal.
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745635
    m_Localized: 'Judith: Hmph. You too. I guess.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745634
    m_Localized: 'Sky: Leave that to me! It was nice to meet you, Judith. Take care.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745633
    m_Localized: "Judith: Hmph. Whatever, it\u2019s none of my business. Crystal
      is straight ahead, underneath that mountain. I don\u2019t know how you\u2019re
      gonna get there, though."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745632
    m_Localized: 'Sky: At least let me try.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745631
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745630
    m_Localized: "Sky: But it doesn\u2019t have to be! Look, you don\u2019t have
      to believe me. But at least let me try. I have the power to reactivate the
      crystal and bring this island back to the mainland!"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745629
    m_Localized: "Judith: That\u2019s\u2013 Ugh! What a load of hogwash. The islands
      are split apart, and they can\u2019t be brought back together. This is how
      we live now."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745628
    m_Localized: "Sky: The Mother Crystal has sent me on a quest to reunite the islands
      of Ethor\u2026which is why I need your help."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745627
    m_Localized: "Sky: And technically that\u2019s still true, I\u2019m just a bit
      of a\u2026special circumstance."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745626
    m_Localized: "Judith: That\u2026that\u2019s not possible. That shouldn\u2019t
      be possible, travel between the islands hasn\u2019t existed since the Fracture."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745625
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745624
    m_Localized: "Sky: No, I\u2019m serious! My sky ship is right over there if you
      don\u2019t believe me."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745623
    m_Localized: 'Judith: Hah. Good one.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745622
    m_Localized: "Sky: I don\u2019t actually. I\u2019m from the Mother island!"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745621
    m_Localized: "Judith: Yes. The crystal that\u2019s been trapped in this big block
      of ice since the fracture. Why do you sound so surprised? You act like you
      don\u2019t live here\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745620
    m_Localized: 'Sky: Wait a minute. Did you say crystal?!'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745619
    m_Localized: "Judith: Yes, well, it\u2019s distracting. Please leave me alone
      so I can continue my work. I\u2019ve got to practice. The crystal\u2019s not
      gonna free itself\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745618
    m_Localized: "Sky: I\u2019ve been told I\u2019m very curious."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745617
    m_Localized: 'Judith: Do you always ask so many questions?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745616
    m_Localized: 'Sky: Why?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745615
    m_Localized: 'Judith: Mining it, obviously.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745614
    m_Localized: 'Sky: What are you doing with your ice?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745613
    m_Localized: 'Judith: Yes MY ICE! By the lake.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745612
    m_Localized: 'Sky: Your ice?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745611
    m_Localized: 'Judith: My ice.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745610
    m_Localized: 'Sky: Like what?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745609
    m_Localized: "Judith: Don\u2019t care. Not my problem. I have other things to
      worry about."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745608
    m_Localized: "Sky: But you don\u2019t even know what I need help with."
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745607
    m_Localized: 'Judith: No.'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745606
    m_Localized: 'Sky: Well, actually, I was hoping you might be able to help me!'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745605
    m_Localized: 'Judith: Judith. What do you want?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745604
    m_Localized: "Sky: I\u2019m Sky, it\u2019s nice to meet you! What's your name?"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745603
    m_Localized: 'Judith: What do you want?'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745602
    m_Localized: 'Sky: Hello!'
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745601
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 2905819790745600
    m_Localized: (Sky arrives on the ice island, and can walk up to Judith and press
      E to interact with her, which will bring up the dialogue.)
    m_Metadata:
      m_Items: []
  - m_Id: 2905819786551296
    m_Localized: "\u2014-----------------------------------------------------------"
    m_Metadata:
      m_Items: []
  - m_Id: 3673697638805504
    m_Localized: 'Penguin NPC: Brrrrr! (What are you doing here?!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620800
    m_Localized: 'Sky: Uh, what?'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620801
    m_Localized: 'Penguin: Brrrrrrrrrrrrrr! (You shall meet your End!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620802
    m_Localized: "Sky: Sorry, I don\u2019t speak penguin."
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620803
    m_Localized: 'Penguin: Br! (Fear me human)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620804
    m_Localized: 'Sky: It was probably just trying to say hello!'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620805
    m_Localized: 'Penguin NPC: Noot Noot! (Nothing on this island is as cold as my
      soul)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620806
    m_Localized: 'Sky: What a cute little guy.'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620807
    m_Localized: 'Penguin NPC: Noot! Noot! (Get off the island while you still can!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620808
    m_Localized: 'Sky: Well, bye!'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620809
    m_Localized: 'Penguin NPC: Nooot! Nooot! (Noooo! The Beast will feast on your
      bones)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620810
    m_Localized: "Penguin NPC: Gak! (I\u2019m training to be able to fly!)"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620811
    m_Localized: "Sky: Sorry little buddy, but penguins can\u2019t fly."
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620812
    m_Localized: "Penguin NPC: Gaaak! (Coward! I\u2019ll show you!)"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620813
    m_Localized: 'Penguin NPC: Quank! (Where is that Bastard!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620814
    m_Localized: 'Sky: Aww! Look at this little cutie!'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620815
    m_Localized: "Penguin NPC: Quack!(I\u2019m looking for that bastard, Marvin!)"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620816
    m_Localized: 'Sky: Aw so cute wiggling their little flippers.'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620817
    m_Localized: 'Penguin NPC: Quank! (That bastard tossed my child over the Island!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620818
    m_Localized: 'Sky: Aww well bye little guy.'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620819
    m_Localized: 'Penguin NPC: Quank! Quank! Quank!(Wait where are you going! Come
      Back! HELP MY CHILD!!!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620820
    m_Localized: 'Penguin NPC: Brrr (You are not a penguin, get out!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620821
    m_Localized: "Sky: Oh my gosh you\u2019re such a cutie patootie!"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620822
    m_Localized: "Penguin NPC: Brr! (I\u2019ll rip your face clean off if you take
      another step!)"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620823
    m_Localized: "Sky: Awww you\u2019re just as sweet as you are adorable!"
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620824
    m_Localized: 'Penguin NPC: Squawk! (Why do we live just to die?)'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620825
    m_Localized: 'Sky: Awww look at this cute little fella! Not a single thought
      behind those eyes!'
    m_Metadata:
      m_Items: []
  - m_Id: 3673699836620826
    m_Localized: 'Penguin NPC: Squuuaaawwk! (Your story will turn its final page
      one day whether you like it or not!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897462583296
    m_Localized: 'Penguin NPC: Brrrrr! (What are you doing here?!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692160
    m_Localized: 'Sky: Uh, what?'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692161
    m_Localized: 'Penguin: Brrrrrrrrrrrrrr! (You shall meet your End!)'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692162
    m_Localized: "Sky: Sorry, I don\u2019t speak penguin."
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692163
    m_Localized: 'Penguin: Br! (Fear me human)'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692164
    m_Localized: 'Sky: It was probably just trying to say hello!'
    m_Metadata:
      m_Items: []
  - m_Id: 3681897529692165
    m_Localized: 'Penguin NPC: Noot Noot! (Nothing on this island is as cold as my
      soul)'
    m_Metadata:
      m_Items: []
