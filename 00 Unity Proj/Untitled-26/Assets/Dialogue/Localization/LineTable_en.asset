  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: e9620f8c34305754d8cc9a7e49e852d9, type: 3}
  m_Name: LineTable_en
  m_EditorClassIdentifier: Unity.Localization::UnityEngine.Localization.Tables.StringTable
  m_LocaleId:
    m_Code: en
  m_SharedData: {fileID: 11400000, guid: c884be7acc7ff0f4db5cf6f4614ad1f2, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 157063204864
    m_Localized: 'Capsley: Hello, I am Mr Capsley.'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839680
    m_Localized: 'Capsley: I''m only going to ask this once'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839681
    m_Localized: 'Capsley: Who are you then?'
    m_Metadata:
      m_Items: []
  - m_Id: 157184839682
    m_Localized: I'm Capsule, but my friends call me "Tic Tac". No idea why...
    m_Metadata:
      m_Items: []
  - m_Id: 157189033984
    m_Localized: The name's Triquandle.
    m_Metadata:
      m_Items: []
  - m_Id: 157189033985
    m_Localized: Pyramid. Why - who wants to know?
    m_Metadata:
      m_Items: []
  - m_Id: 157189033986
    m_Localized: 'Capsley: Nice to meet you {0}!'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228288
    m_Localized: 'Capsley: No need to be so rude...'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228289
    m_Localized: 'Capsley: Maybe you should be called Grumpy {0}.'
    m_Metadata:
      m_Items: []
  - m_Id: 157193228290
    m_Localized: I said I would only say it once
    m_Metadata:
      m_Items: []
  - m_Id: 13033750294982656
    m_Localized: "Mother Crystal:\u201COr at least, so it used to be\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228292
    m_Localized: "Mother Crystal:\u201CChild of the sky\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228293
    m_Localized: "Mother Crystal:\u201CDo you hear my voice?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228294
    m_Localized: "Mother Crystal:\"I am the heart and soul of The Islands of Ethor.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228295
    m_Localized: "Mother Crystal:\u201CIt is through I that the islands stay bound
      as one.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228302
    m_Localized: "Mother Crystal:\u201CChild\u2026Hear my plea\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228303
    m_Localized: "Mother Crystal:\u201CThe binding light of the Isles of Ethor is
      fading\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 157193228304
    m_Localized: "Mother Crystal:\u201CThe islands cry out for a hero, and the land
      yearns to restore its unity\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151493914624
    m_Localized: "???: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800704
    m_Localized: 'Sky: Hello!'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800705
    m_Localized: '???: What do you want?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800706
    m_Localized: "Sky: I\u2019m Sky, it\u2019s nice to meet you! What's your name?"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800707
    m_Localized: '???: Judith. What do you want?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800708
    m_Localized: 'Sky: Well, actually, I was hoping you might be able to help me!'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800709
    m_Localized: 'Judith: No.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800710
    m_Localized: "Sky: But you don\u2019t even know what I need help with."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800711
    m_Localized: "Judith: Don\u2019t care. Not my problem. I have other things to
      worry about."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800712
    m_Localized: 'Sky: Like what?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800713
    m_Localized: 'Judith: My ice.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800714
    m_Localized: 'Sky: Your ice?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800715
    m_Localized: 'Judith: Yes MY ICE! By the lake.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800716
    m_Localized: 'Sky: What are you doing with your ice?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800717
    m_Localized: 'Judith: Mining it, obviously.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800718
    m_Localized: 'Sky: Why?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800719
    m_Localized: 'Judith: Do you always ask so many questions?'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800720
    m_Localized: "Sky: I\u2019ve been told I\u2019m very curious."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800721
    m_Localized: "Judith: Yes, well, it\u2019s distracting. Please leave me alone
      so I can continue my work. I\u2019ve got to practice. The crystal\u2019s not
      gonna free itself\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800722
    m_Localized: 'Sky: Wait a minute. Did you say crystal?!'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800723
    m_Localized: "Judith: Yes. The crystal that\u2019s been trapped in this big block
      of ice since the fracture. Why do you sound so surprised? You act like you
      don\u2019t live here\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800724
    m_Localized: "Sky: I don\u2019t actually. I\u2019m from the Mother island!"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800725
    m_Localized: 'Judith: Hah. Good one.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800726
    m_Localized: "Sky: No, I\u2019m serious! My sky ship is right over there if you
      don\u2019t believe me."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800727
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800728
    m_Localized: "Judith: That\u2026that\u2019s not possible. That shouldn\u2019t
      be possible, travel between the islands hasn\u2019t existed since the Fracture."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800729
    m_Localized: "Sky: And technically that\u2019s still true, I\u2019m just a bit
      of a\u2026special circumstance."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800730
    m_Localized: "Sky: The Mother Crystal has sent me on a quest to reunite the islands
      of Ethor\u2026which is why I need your help."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800731
    m_Localized: "Judith: That\u2019s\u2013 Ugh! What a load of hogwash. The islands
      are split apart, and they can\u2019t be brought back together. This is how
      we live now."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800732
    m_Localized: "Sky: But it doesn\u2019t have to be! Look, you don\u2019t have
      to believe me. But at least let me try. I have the power to reactivate the
      crystal and bring this island back to the mainland!"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800733
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800734
    m_Localized: 'Sky: At least let me try.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800735
    m_Localized: "Judith: Hmph. Whatever, it\u2019s none of my business. Crystal
      is straight ahead, underneath that mountain. I don\u2019t know how you\u2019re
      gonna get there, though."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800736
    m_Localized: 'Sky: Leave that to me! It was nice to meet you, Judith. Take care.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800737
    m_Localized: 'Judith: Hmph. You too. I guess.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800738
    m_Localized: 'Judith: Back already? I knew you were full of it.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800739
    m_Localized: 'Sky: I told you I could do it!'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800740
    m_Localized: "Judith: I\u2026I don\u2019t believe it."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800741
    m_Localized: "Judith: \u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800742
    m_Localized: 'Judith: Thank you.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800743
    m_Localized: 'Sky: Of course, Judith. I hope things can get a little easier for
      you now.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800744
    m_Localized: "Judith: You\u2019re going to go to all the islands, right?"
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800745
    m_Localized: "Sky: That\u2019s the plan."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800746
    m_Localized: "Judith: Good. That\u2019s good."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800747
    m_Localized: "Judith: I don\u2019t know the specifics, but I\u2019m sure they
      also have problems related to their crystals."
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800748
    m_Localized: 'Judith: Make sure you talk to them.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800749
    m_Localized: 'Sky: Can do.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800750
    m_Localized: 'Sky: I wish you the best, Judith.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800751
    m_Localized: 'Judith: You too. And I really do mean that.'
    m_Metadata:
      m_Items: []
  - m_Id: 4026151577800752
    m_Localized: "Judith: Best of luck on your journey. I\u2019m sure you\u2019re
      gonna need it."
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701335
    m_Localized: "Sky: Awww you\u2019re just as sweet as you are adorable!"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701336
    m_Localized: 'Penguin: Squawk! (Why do we live just to die?)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701337
    m_Localized: 'Sky: Awww look at this cute little fella! Not a single thought
      behind those eyes!'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701338
    m_Localized: 'Penguin: Squuuaaawwk! (Your story will turn its final page one
      day whether you like it or not!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701334
    m_Localized: "Penguin: Brr! (I\u2019ll rip your face clean off if you take another
      step!)"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701333
    m_Localized: "Sky: Oh my gosh you\u2019re such a cutie patootie!"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701332
    m_Localized: 'Penguin: Brrr (You are not a penguin, get out!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701331
    m_Localized: 'Penguin: Quank! Quank! Quank!(Wait where are you going! Come Back!
      HELP MY CHILD!!!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701330
    m_Localized: 'Sky: Aww well bye little guy.'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701329
    m_Localized: 'Penguin: Quank! (That bastard tossed my child over the Island!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701328
    m_Localized: 'Sky: Aw so cute wiggling their little flippers.'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701327
    m_Localized: "Penguin: Quack!(I\u2019m looking for that bastard, Marvin!)"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701326
    m_Localized: 'Sky: Aww! Look at this little cutie!'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701325
    m_Localized: 'Penguin: Quank! (Where is that Bastard!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701324
    m_Localized: "Penguin: Gaaak! (Coward! I\u2019ll show you!)"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701323
    m_Localized: "Sky: Sorry little buddy, but penguins can\u2019t fly."
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701322
    m_Localized: "Penguin: Gak! (I\u2019m training to be able to fly!)"
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701321
    m_Localized: 'Penguin: Nooot! Nooot! (Noooo! The Beast will feast on your bones)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701320
    m_Localized: 'Sky: Well, bye!'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701319
    m_Localized: 'Penguin: Noot! Noot! (Get off the island while you still can!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701318
    m_Localized: 'Sky: What a cute little guy.'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701317
    m_Localized: 'Penguin: Noot Noot! (Nothing on this island is as cold as my soul)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701316
    m_Localized: 'Sky: It was probably just trying to say hello!'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701315
    m_Localized: 'Penguin: Br! (Fear me human)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701314
    m_Localized: "Sky: Sorry, I don\u2019t speak penguin."
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701313
    m_Localized: 'Penguin: Brrrrrrrrrrrrrr! (You shall meet your End!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983522701312
    m_Localized: 'Sky: Uh, what?'
    m_Metadata:
      m_Items: []
  - m_Id: 4488983518507008
    m_Localized: 'Penguin: Brrrrr! (What are you doing here?!)'
    m_Metadata:
      m_Items: []
  - m_Id: 4488044673888256
    m_Localized: 'Judith: You too. And I really do mean that.'
    m_Metadata:
      m_Items: []
  - m_Id: 13042942170918916
    m_Localized: <b>Talk to Dad at the dock</b>
    m_Metadata:
      m_Items: []
  - m_Id: 13042942170918915
    m_Localized: "Sky: \u201CDad\u2019s already out fixing an airship, as usual.
      Maybe he knows what that was.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 13042942170918914
    m_Localized: "Sky: \u201CI don\u2019t know what that was, but it all felt so\u2026
      real.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 13042942170918913
    m_Localized: "Sky: \u201CChild of the sky\u2026 hear my plea\u2026 and a hero??\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 13042942170918912
    m_Localized: "Sky: \u201CThat voice\u2026 what was that?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353689665536
    m_Localized: "Cumulus: \u201CWhat\u2019s up, kiddo? You\u2019re up early.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353756774400
    m_Localized: "Cumulus: \u201CHmmm, you look like you got thunderclouds crashing
      in your head.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353756774401
    m_Localized: "Sky: \u201C...Dad I think I heard something\u2026 A voice, and
      it called for me!\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353756774402
    m_Localized: "Cumulus: \u201CThe wind carries many voices across Ethor. Most
      people have stopped listening\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353756774403
    m_Localized: "Sky: \u201CDad! Listen to me! Something about it felt so\u2026
      real\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353756774404
    m_Localized: "Cumulus: \u201CReal, you say? What did you hear, then?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163008
    m_Localized: "Sky: \u201CIt said the islands are in danger, and something about
      a hero, and -\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163009
    m_Localized: "Cumulus: \u201CA hero\u2026 so the Mother Crystal truly has called
      for you\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163010
    m_Localized: "Sky: \u201CWhat? How do you know, dad?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163011
    m_Localized: "Cumulus: \u201CWhen you were younger you also mentioned that voice.
      I thought that, over time, maybe you had forgotten\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163012
    m_Localized: "Cumulus: \u201CBut the fact of the matter is that you\u2019ve always
      had the strongest connection to the crystal more than the rest of us on the
      island."
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163013
    m_Localized: "Cumulus: And if you feel called\u2026 you should go see her.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15575353765163014
    m_Localized: <b>Go to Mother Crystal</b>
    m_Metadata:
      m_Items: []
  - m_Id: 15626577354493952
    m_Localized: "Cumulus: \u201CWhat\u2019s up, kiddo? You\u2019re up early.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048384
    m_Localized: "Cumulus: \u201CHmmm, you look like you got thunderclouds crashing
      in your head.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048385
    m_Localized: "Sky: \u201C...Dad I think I heard something\u2026 A voice, and
      it called for me!\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048386
    m_Localized: "Cumulus: \u201CThe wind carries many voices across Ethor. Most
      people have stopped listening\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048387
    m_Localized: "Sky: \u201CDad! Listen to me! Something about it felt so\u2026
      real\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048388
    m_Localized: "Cumulus: \u201CReal, you say? What did you hear, then?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048389
    m_Localized: "Sky: \u201CIt said the islands are in danger, and something about
      a hero, and -\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048390
    m_Localized: "Cumulus: \u201CA hero\u2026 so the Mother Crystal truly has called
      for you\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048391
    m_Localized: "Sky: \u201CWhat? How do you know, dad?\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048392
    m_Localized: "Cumulus: \u201CWhen you were younger you also mentioned that voice.
      I thought that, over time, maybe you had forgotten\u2026\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048393
    m_Localized: "Cumulus: \u201CBut the fact of the matter is that you\u2019ve always
      had the strongest connection to the crystal more than the rest of us on the
      island."
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048394
    m_Localized: "Cumulus: And if you feel called\u2026 you should go see her.\u201D"
    m_Metadata:
      m_Items: []
  - m_Id: 15626577388048395
    m_Localized: <b>Go to Mother Crystal</b>
    m_Metadata:
      m_Items: []
  - m_Id: 16022161907380224
    m_Localized: This is an example of a Yarn Spinner script. Write your dialogue
      here!
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537479
    m_Localized: 'Sky: But I appreciate the support, I guess...'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537478
    m_Localized: 'Sky: Okay... just gonna ignore the treason bit for now.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537477
    m_Localized: thing?
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537476
    m_Localized: 'Sign Crab: It might be a little tricky for someone with just two
      legs but I believe in you, fleshy...'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537475
    m_Localized: 'Sign Crab: ANYWAYS... The guards came through and made a little
      path for you.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537474
    m_Localized: "Sky: Wait. Wha\u2013"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537473
    m_Localized: 'Sign Crab: If I say too much, I might get accused of treason.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537472
    m_Localized: 'Sign Crab: Yeah... Sorry about that.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537471
    m_Localized: 'Sky: I think "unpredictable" was an understatement.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537470
    m_Localized: "Sign Crab: You\u2019ve returned! Somehow alive..."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537469
    m_Localized: "Sign Crab: Okay... I\u2019ll have to keep that in mind."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537468
    m_Localized: 'Sign Crab: Our king can be a bit... unpredictable.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537467
    m_Localized: "Sign Crab: I\u2019ll let you leave with this warning..."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537466
    m_Localized: 'Sky: Appreciate the help.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537465
    m_Localized: "Sign Crab: That\u2019s where the king resides."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537464
    m_Localized: "Sign Crab: There\u2019s a big oasis located across from those splintered
      islands over there."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537463
    m_Localized: 'Sky: Where might I find this king of yours?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537462
    m_Localized: the king.
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537461
    m_Localized: "Sign Crab: If you don\u2019t want to be branded as a trespasser,
      you better seek an audience with"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537460
    m_Localized: "Sign Crab: You\u2019re clearly not from around here..."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537459
    m_Localized: 'Sky: Thanks for the heads up.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537458
    m_Localized: "Sign Crab: Because over there are the burning sands. You\u2019ll
      DIE if you try to cross it."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537457
    m_Localized: 'Sky: Woah! Why not?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537456
    m_Localized: 'Sign Crab: STOP, FLESHY CREATURE! DO NOT GO FORWARD!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537455
    m_Localized: 'Sky: Jeez. That was a bit harsh.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537454
    m_Localized: "Crab Citizen: ABSOLUTELY NOT! I\u2019m not consorting with the
      likes of you!"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537453
    m_Localized: "Sky: Hold on jus\u2013"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537452
    m_Localized: 'Crab Citizen: YOU''RE A TRESPASSER?!?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537451
    m_Localized: 'Crab Citizen: Unless...'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537450
    m_Localized: Karkinos...
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537449
    m_Localized: "Crab Citizen: I can\u2019t believe someone on this island doesn\u2019t
      know about the Crab God,"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537448
    m_Localized: 'Sky: Whose Karkinos?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537447
    m_Localized: "Crab Citizen: Praise be Karkinos! He\u2019s given us a truly just
      king!"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537446
    m_Localized: 'Crab Citizen: Why, only the greatest king in our history!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537445
    m_Localized: 'Sky: Who''s King Julien?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537444
    m_Localized: 'Crab Citizen: All hail King Julien!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537443
    m_Localized: journey, trespasser.
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537442
    m_Localized: "Julien: You\u2019ve done a great service to my kingdom and have
      my thanks. I wish you luck on your"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537441
    m_Localized: "Sky: Great. I can\u2019t wait to get out of this heat\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537440
    m_Localized: 'Julien: It will be docked by where you first arrived.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537439
    m_Localized: "Julien: Anyway, I\u2019ll have my people prepare your vessel for
      your next voyage."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537438
    m_Localized: "Julien: I thought you\u2019d surely perish."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537437
    m_Localized: 'Julien: Yes, of course! I do apologize for my rudeness.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537436
    m_Localized: 'Sky: Can I leave now?'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537435
    m_Localized: "Julien: Oh? That\u2019s excellent news! I shall inform my people
      that our lands are now cleansed."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537434
    m_Localized: 'Sky: No! No dungeon! I did as you asked.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537433
    m_Localized: "Julien: Back already, trespasser? Have you completed your task?
      Or will I have to send you to the dungeon for one million years\u2013"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537432
    m_Localized: 'Julien: Now GO! May Karkinos bless your venture!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537431
    m_Localized: "Sky: Thank you, King Julien. I appreciate your\u2026kindness."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537430
    m_Localized: with safe passage.
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537429
    m_Localized: "Julien: Once you\u2019ve completed your task, inform one of my
      followers, and I shall provide you"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537428
    m_Localized: 'Julien: A MILLION-YEARS IN THE DUNGEON!!!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537427
    m_Localized: 'Julien: Should you refuse this task or fail in your attempt, it
      will be...'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537426
    m_Localized: "Julien: So, once you\u2019ve made it to the other side, we won\u2019t
      be able to assist you any further."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537425
    m_Localized: "Julien: However, my people\u2019s crustacean bodies can\u2019t
      stand the heat for too long."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537424
    m_Localized: "Julien: And yet, it\u2019s all you shall receive! My guard shall
      provide you with some assistance in crossing the hot sands."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537423
    m_Localized: "Sky: That\u2019s not much of a reward..."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537422
    m_Localized: 'Julien: Do this, and I shall reward you with your life and passage
      out of my lands.'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537421
    m_Localized: 'Julien: Silence! And pay attention! Now, my quest to you is to
      find the source of this treachery and DESTROY IT!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537420
    m_Localized: 'Sky: Hey, that rhymes!'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537419
    m_Localized: "Julien: Recently this island seems to be plagued by some unknown
      sorcery! Crops aren\u2019t growing, currents are slowing, and the light of
      day is dimly glowing..."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537418
    m_Localized: importance.
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537417
    m_Localized: 'Julien: Before I can allow you to leave my lands, you must embark
      on a quest of utmost'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537416
    m_Localized: "Julien: So I\u2019ll allow you to keep your life. However!"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537415
    m_Localized: "Sky: That\u2019s good. I think."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537414
    m_Localized: "Julien: Lucky for you, trespasser, I\u2019m feeling merciful today."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537413
    m_Localized: 'Julien: How interesting...'
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537412
    m_Localized: "Julien: Your kind is unlike anything I\u2019ve ever seen before."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537411
    m_Localized: "Julien: Sky\u2026hm\u2026quite the unique intruder you are."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537410
    m_Localized: "Sky: I\u2019m not trespassing! I\u2019m here to help, honest! My
      name is Sky."
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537409
    m_Localized: "Julien: Who dares to trespass upon King Julien\u2019s domain?!"
    m_Metadata:
      m_Items: []
  - m_Id: 16031158043537408
    m_Localized: "???: Well, well, well\u2026"
    m_Metadata:
      m_Items: []
  - m_Id: 16456455292223488
    m_Localized: 'King Julien: What the hell are you doing?!'
    m_Metadata:
      m_Items: []
  - m_Id: 16456455321583616
    m_Localized: "Sky: I jus\u2013"
    m_Metadata:
      m_Items: []
  - m_Id: 16456455321583617
    m_Localized: 'King Julien: GO FINISH YOUR MISSION TRESSPASSER!'
    m_Metadata:
      m_Items: []
  references:
    version: 2
    RefIds: []
